    "better-auth": "^1.5.0",
    "better-result": "^2.9.2",
    "hono": "^4.10.8",
    "mimetext": "^3.0.27",
    "postal-mime": "^2.6.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
